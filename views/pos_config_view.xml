<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_config_form_manual_weight_custom" model="ir.ui.view">
        <field name="name">pos.config.form.manual.weight.custom</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!-- On ajoute notre bloc à la fin du sheet -->
            <xpath expr="//sheet" position="inside">
                <group string="Poids manuel (ChatGPT)">
                    <field name="x_min_weight_grams"/>
                    <field name="x_max_weight_grams"/>
                    <field name="x_enable_weight_note"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
